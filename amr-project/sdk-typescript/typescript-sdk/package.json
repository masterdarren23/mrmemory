{
  "name": "memorymr",
  "version": "0.1.0",
  "description": "Agent Memory Relay — persistent long-term memory for AI agents",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
