# AMR Environment Configuration
# Copy to .env and fill in values. NEVER commit .env to git.

# ---- API Server ----
PORT=8080
RUST_LOG=info
API_BASE_URL=http://localhost:8080

# ---- PostgreSQL ----
DATABASE_URL=postgres://amr:amr-dev-only@localhost:5432/amr

# ---- Qdrant ----
QDRANT_URL=http://localhost:6333
# QDRANT_API_KEY=           # Set for Qdrant Cloud

# ---- Redis ----
REDIS_URL=redis://localhost:6379

# ---- Embedding Model ----
EMBEDDING_PROVIDER=openai    # openai | local
OPENAI_API_KEY=sk-...        # Required if EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-ada-002
EMBEDDING_DIMENSION=1536

# ---- Auth ----
JWT_SECRET=change-me-in-production-use-64-random-bytes
API_KEY_HASH_SALT=change-me-in-production

# ---- Rate Limiting ----
RATE_LIMIT_STARTER=100       # req/min for starter plan
RATE_LIMIT_PRO=1000          # req/min for pro plan

# ---- External Services (Production) ----
# FLY_API_TOKEN=             # Fly.io deploy token
# SENTRY_DSN=                # Error tracking
# STRIPE_SECRET_KEY=         # Billing
# STRIPE_WEBHOOK_SECRET=     # Stripe webhooks
